{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 24
	},

	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"ee_WARNINGS_AS_ERRORS" : "OFF",
				"ee_CLANG_TIDY" : "ON",
				"ee_CPPCHECK" : "ON"
			}
		},
		{
			"name": "debug",
			"inherits": "base",
			"hidden": true,
			"cacheVariables": {
				"ee_IPO" : "OFF",
				"CMAKE_BUILD_TYPE": "Debug",
				"ee_BUILD_TESTS": "ON"
			}
		},
		{
			"name": "release",
			"inherits": "base",
			"hidden": true,
			"cacheVariables": {
				"ee_IPO" : "ON",
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "gcc-debug",
			"inherits": "debug",
			"cacheVariables": {
				"CMAKE_CXX_COMPILER": "g++",
				"USE_COMPILER": "gcc"
			}
		},
		{
			"name": "gcc-release",
			"inherits": "release",
			"cacheVariables": {
				"CMAKE_CXX_COMPILER": "g++",
				"USE_COMPILER": "gcc"
			}
		},
		{
			"name": "clang-debug",
			"inherits": "debug",
			"cacheVariables": {
				"CMAKE_CXX_COMPILER": "clang++",
				"USE_COMPILER": "clang"
			}
		},
		{
			"name": "clang-release",
			"inherits": "release",
			"cacheVariables": {
				"CMAKE_CXX_COMPILER": "clang++",
				"USE_COMPILER": "clang"
			}
		},
		{
			"name": "asan-ubsan",
			"inherits": "clang-debug",
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "-fsanitize=address,undefined,leak -fno-omit-frame-pointer"
			}
		},
		{
			"name": "tsan",
			"inherits": "clang-debug",
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "-fsanitize=thread"
			}
		},
		{
			"name": "msan",
			"inherits": "clang-debug",
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "-fsanitize=memory"
			}
		}
	],

	"buildPresets": [
		{
			"name": "gcc-debug",
			"configurePreset": "gcc-debug"
		},
		{
			"name": "gcc-release",
			"configurePreset": "gcc-release"
		},
		{
			"name": "clang-debug",
			"configurePreset": "clang-debug"
		},
		{
			"name": "clang-release",
			"configurePreset": "clang-release"
		},
		{
			"name": "asan-ubsan",
			"configurePreset": "asan-ubsan"
		},
		{
			"name": "tsan",
			"configurePreset": "tsan"
		},
		{
			"name": "msan",
			"configurePreset": "msan"
		}
	]
}
